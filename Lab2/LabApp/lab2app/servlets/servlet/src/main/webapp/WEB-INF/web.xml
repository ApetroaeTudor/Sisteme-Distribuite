<!DOCTYPE web-app PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN" "http://java.sun.com/dtd/web-app_2_3.dtd">
<web-app>
    <display-name>Web Component App</display-name>
    <servlet>
        <servlet-name>ProcessStudent</servlet-name>
        <servlet-class>ProcessStudentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>FetchStudentList</servlet-name>
        <servlet-class>FetchStudentListServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UpdateStudent</servlet-name>
        <servlet-class>UpdateStudentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DisplayError</servlet-name>
        <servlet-class>DisplayErrorServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ConfigConstraints</servlet-name>
        <servlet-class>ConfigConstraintsServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ProcessStudent</servlet-name>
        <url-pattern>/process-student</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>FetchStudentList</servlet-name>
        <url-pattern>/fetch-student-list</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateStudent</servlet-name>
        <url-pattern>/update-student</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DisplayError</servlet-name>
        <url-pattern>/display-error</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ConfigConstraints</servlet-name>
        <url-pattern>/config</url-pattern>
    </servlet-mapping>

</web-app>